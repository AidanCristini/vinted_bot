# .env.example - Environment variable template for Vinted Notifier
# Copy this file to .env and fill in your values

# ===========================================
# DISCORD NOTIFICATIONS (Primary)
# ===========================================
# Create a webhook in your Discord server:
# Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=

# ===========================================
# DATABASE
# ===========================================
# SQLite database path (default works for Docker)
DATABASE_URL=sqlite+aiosqlite:///data/vinted.db

# ===========================================
# APPLICATION
# ===========================================
# Path to config file
CONFIG_PATH=config.yaml

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Set to true to only print notifications to console (no actual sending)
DRY_RUN=false
