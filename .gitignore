venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.hypothesis/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter
.ipynb_checkpoints/

# Data and secrets
data/
*.db
*.sqlite
*.sqlite3
.env
.env.local
.env.*.local
config.yaml
!config.example.yaml

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
